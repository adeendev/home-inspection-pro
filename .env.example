# ─────────────────────────────────────────────
# Home Inspection Pro — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Public vars (NEXT_PUBLIC_ prefix) are inlined at build time
# and shipped to the browser. NEVER put secrets here.
#
# Server-only vars are read via process.env in server
# code (API routes or server components).
# ─────────────────────────────────────────────

# ── Stripe (Payment Processing) ──────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Get this from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── App ─────────────────────────────────────
NODE_ENV=development
