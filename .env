# ─────────────────────────────────────────────
# Home Inspection Pro — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Public vars (VITE_ prefix) are inlined at build time
# and shipped to the browser. NEVER put secrets here.
#
# Server-only vars are read via process.env in server
# code (.server.ts files or createServerFn handlers).
# ─────────────────────────────────────────────

# ── Stripe (Payment Processing) ──────────────
# Get these from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Get this from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── App ─────────────────────────────────────
NODE_ENV=development
# Public URL of the deployed app (used for SEO, sitemap, etc.)
# VITE_APP_URL=http://localhost:3000

# ── Future / Optional ───────────────────────
# Add other service keys below as needed:
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.us.sentry.io/xxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxx
